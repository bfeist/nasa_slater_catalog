# =============================================================================
# Slater Film Catalog — Docker environment template
# Copy to .env.docker and adjust values.  .env.docker is gitignored.
#
# These variables configure the Express API container.  All paths are
# container-internal paths that correspond to the volume mounts in
# docker-compose.yml.
# =============================================================================

# ---------------------------------------------------------------------------
# Runtime environment
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=9301

# ---------------------------------------------------------------------------
# Container-internal paths (match volume mounts in docker-compose.yml)
# ---------------------------------------------------------------------------

# SQLite catalog database
DB_PATH=/app/database/catalog.db

# Scanned shotlist PDFs
SHOTLIST_PDF_DIR=/app/static_assets/shotlist_pdfs

# LLM OCR JSON outputs
LLM_OCR_DIR=/app/static_assets/llm_ocr

# Path to auth.config.json inside the container
AUTH_CONFIG_PATH=/app/auth.config.json

# Root of the NASA video archive (mounted from VIDEO_ARCHIVE_HOST_PATH below)
VIDEO_ARCHIVE_ROOT=/archive

# ---------------------------------------------------------------------------
# Fonts (DejaVu installed in the container via apk)
# Alpine installs to /usr/share/fonts/dejavu/ (not .../truetype/dejavu/)
# ---------------------------------------------------------------------------
WATERMARK_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSans.ttf
WATERMARK_MONO_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSansMono.ttf

# ---------------------------------------------------------------------------
# Secrets — change these!
# ---------------------------------------------------------------------------

# HMAC key for deriving Slater numbers (SFR-XXXXXX).
# Must match what was used when the catalog DB was built.
SLATER_SECRET=stephen-slater-nasa-catalog

# ---------------------------------------------------------------------------
# Frontend pass-through control
# "false" → Express does NOT serve the SPA (Nginx handles it)
# "true"  → Express serves the SPA directly (single-container mode)
# ---------------------------------------------------------------------------
SERVE_FRONTEND=false
