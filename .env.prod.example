# =============================================================================
# Production catalog API — environment template
# Copy to .env.prod on the production host. Used by compose.prod.yml.
# Catalog mode is implied by HOME_GATEWAY_BASE_URL being set.
# =============================================================================

NODE_ENV=production
PORT=9301

# Container-internal paths
DB_PATH=/app/database/catalog.db
AUTH_CONFIG_PATH=/app/auth.config.json

# Express must NOT serve the SPA — host Nginx does
SERVE_FRONTEND=false

LOG_DIR=/app/logs
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Home gateway split (REQUIRED on production)
# ---------------------------------------------------------------------------

# Public URL of the home video gateway (no trailing slash)
HOME_GATEWAY_BASE_URL=https://home.example.com

# Shared bearer secret — must match HOME_GATEWAY_SHARED_SECRET on the gateway.
# Generate with:  openssl rand -base64 48
HOME_GATEWAY_SHARED_SECRET=change-me-to-a-strong-random-value

# Cache TTL for the gateway /healthz probe (seconds)
HOME_GATEWAY_HEALTH_TTL_SECS=30

# Build/release version tag (set by CI; also used by the frontend cache buster)
RELEASE_VERSION=dev

# ---------------------------------------------------------------------------
# Secrets — must match the values used during DB creation
# ---------------------------------------------------------------------------
SLATER_SECRET=change-me-to-a-strong-random-value

# Production catalog has no local PDFs and no archive mount — do not set
# SHOTLIST_PDF_DIR or VIDEO_ARCHIVE_ROOT here.
