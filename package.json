{
  "name": "nasa-slater-catalog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "rimraf ./.local/express/dist && npm run api:build && concurrently --names \"vite,esbuild,server\" \"npm run dev:vite\" \"npm run api:build:watch\" \"npm run api:serve:dev\"",
    "dev:vite": "vite",
    "dev:force": "vite --force",
    "build": "npm run build:vite && npm run api:build",
    "build:vite": "vite build --emptyOutDir",
    "preview": "vite preview",
    "api:build": "node esbuild.mjs",
    "api:build:watch": "npm run api:build -- --watch",
    "api:serve": "node ./.local/express/dist/api.js",
    "api:serve:dev": "cross-env NODE_ENV=development node --watch --watch-preserve-output ./.local/express/dist/api.js",
    "api:prod": "cross-env NODE_ENV=production node ./.local/express/dist/api.js",
    "start": "npm run api:prod",
    "tsc": "tsc --pretty",
    "tsc:server": "tsc -p tsconfig.server.json --pretty",
    "lint": "concurrently --names \"eslint,stylelint\" \"npm run lint:js\" \"npm run lint:css\"",
    "lint:fix": "concurrently --names \"eslint,stylelint\" \"npm run lint:js:fix\" \"npm run lint:css:fix\"",
    "lint:js": "eslint . --color",
    "lint:js:fix": "eslint . --color --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "test": "vitest run",
    "test:monitor": "vitest",
    "test:ui": "vitest --ui",
    "test:all": "npm run lint && npm run tsc && npm run tsc:server && npm run build && npm run test"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "pretty-bytes": "^7.1.0",
    "rimraf": "^6.1.3",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
