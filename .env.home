# =============================================================================
# Home video gateway — environment template
# Copy to .env.home on the home machine. Used by compose.home.yml.
# =============================================================================

NODE_ENV=production
HOME_GATEWAY_ROLE=home
PORT=9302

# Container-internal paths (match compose.home.yml volume mounts)
DB_PATH=/app/database/catalog.db
SHOTLIST_PDF_DIR=/app/static_assets/shotlist_pdfs
VIDEO_ARCHIVE_ROOT=/archive

WATERMARK_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSans.ttf
WATERMARK_MONO_FONT_PATH=/usr/share/fonts/dejavu/DejaVuSansMono.ttf

# ---------------------------------------------------------------------------
# Token / session config
# ---------------------------------------------------------------------------

# Playback-start window (seconds). Token must be redeemed within this period
# to begin playback; once playback starts there is no per-second cap.
SESSION_TTL_SECS=300

# PDF token lifetime (seconds)
PDF_TOKEN_TTL_SECS=300

# ---------------------------------------------------------------------------
# Auth + CORS
# ---------------------------------------------------------------------------

# Must match HOME_GATEWAY_SHARED_SECRET on the production catalog
HOME_GATEWAY_SHARED_SECRET=stephen-slater-nasa-catalog

# CORS allow-origin for /stream and /pdf — set to the production site origin
PUBLIC_ORIGIN=https://slaterfilmcatalog.benfeist.com

# Build/release version tag (sanity check against catalog requests)
RELEASE_VERSION=dev

# Slater HMAC — same value as production (DB integrity)
SLATER_SECRET=stephen-slater-nasa-catalog

LOG_DIR=/app/logs
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# CIFS share credentials (used by compose.home.yml volume definition in PROD)
# ---------------------------------------------------------------------------
NAS_HOST=192.168.0.6
NAS_SHARE=NASA Archive
NAS_USER=
NAS_PASS=

# ---------------------------------------------------------------------------
# Local-test only (used by compose.home.local.yml)
# Path on the host that contains the archive — bind-mounted into /archive.
# On Windows + GitBash, /o is the mounted O: drive.
# ---------------------------------------------------------------------------
